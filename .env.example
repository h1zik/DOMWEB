# PostgreSQL — contoh Neon / Supabase / RDS / lokal Docker
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dominatus?schema=public"

# Admin panel (/admin) — wajib untuk login & simpan konten
ADMIN_PASSWORD="ganti-password-ini"
# String acak panjang untuk menandatangani cookie sesi
ADMIN_SESSION_SECRET="ganti-dengan-random-panjang"

# --- File upload (logo, gambar hero, PDF, dll.) ---
# Folder penyimpanan file yang diunggah lewat panel Admin → tab Media.
# Lokal: relatif ke root proyek. Production (Railway): path absolut + volume mount.
# Contoh Railway: buat volume, mount ke /data/uploads, lalu:
# UPLOADS_DIR=/data/uploads
UPLOADS_DIR="./data/uploads"

# URL publik situs (tanpa slash di akhir). Dipakai untuk favicon/metadata absolut.
# Contoh: https://dominatus.up.railway.app
NEXT_PUBLIC_SITE_URL=
